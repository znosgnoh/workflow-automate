# Required — PostgreSQL (Neon, Vercel Postgres, or local)
DATABASE_URL="postgresql://..."

# Storage
# local: files in ./output/{runId}/ with download via /api/artifacts/[id]/download
# blob: requires BLOB_READ_WRITE_TOKEN (auto-fallback to local when token missing)
BLOB_READ_WRITE_TOKEN=""
STORAGE_MODE="local"

# Costco — set COSTCO_USE_MOCK=true for offline dev and CI
COSTCO_USE_MOCK="true"
COSTCO_API_URL="https://gdx-api.costco.com/catalog/search/api/v1/search"
COSTCO_CLIENT_IDENTIFIER=""
COSTCO_VISITOR_ID=""
COSTCO_CLIENT_ID="USBC"
COSTCO_LOCALE="en-US"
COSTCO_SEARCH_RESULT_PROVIDER="GRS"
COSTCO_WAREHOUSE_ID="1-wh"
COSTCO_SHIP_TO_POSTAL="98101"
COSTCO_SHIP_TO_STATE="WA"
COSTCO_PAGE_SIZE="999"
# Optional JSON array or comma-separated list; defaults in config/costco-search-defaults.json
# COSTCO_DELIVERY_LOCATIONS='["1-wh","847_NA-wm"]'

# PPT template (generate starter: npm run generate:ppt-template)
PPT_TEMPLATE_PATH="templates/costco-ongoing-products.pptx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Vercel sets this automatically in production
# VERCEL=1
