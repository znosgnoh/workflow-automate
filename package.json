{
  "name": "workflow-automate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:reset": "rm -rf .next && prisma generate && next dev",
    "build": "prisma migrate deploy && rm -rf node_modules/.prisma && prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "verify:excel": "tsx scripts/verify-excel-export.mts",
    "verify:ppt": "tsx scripts/verify-ppt-export.mts",
    "verify:pipeline": "tsx scripts/verify-pipeline-performance.mts",
    "ci": "npm run lint && npm run typecheck && npm run verify:pipeline",
    "generate:ppt-template": "tsx scripts/generate-ppt-template.mts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@vercel/blob": "^2.5.0",
    "@vercel/functions": "^3.7.4",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "next": "16.2.9",
    "pngjs": "^7.0.0",
    "pptxgenjs": "^4.0.1",
    "prisma": "^6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
